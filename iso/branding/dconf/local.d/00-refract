[org/gnome/desktop/background]
picture-uri='file:///usr/share/backgrounds/refract-os.png'
picture-uri-dark='file:///usr/share/backgrounds/refract-os.png'
picture-options='zoom'
primary-color='#0b0b0d'

[org/gnome/desktop/screensaver]
picture-uri='file:///usr/share/backgrounds/refract-os.png'
picture-options='zoom'
primary-color='#0b0b0d'

[org/gnome/desktop/interface]
color-scheme='prefer-dark'
gtk-theme='WhiteSur-Dark'
icon-theme='WhiteSur-dark'
enable-hot-corners=true

[org/gnome/shell]
favorite-apps=['firefox_firefox.desktop', 'org.gnome.Nautilus.desktop', 'org.gnome.Terminal.desktop', 'org.gnome.Settings.desktop', 'install-refract-os.desktop']
enabled-extensions=['ubuntu-dock@ubuntu.com', 'user-theme@gnome-shell-extensions.gcampax.github.com', 'blur-my-shell@aunetx']

[org/gnome/shell/extensions/blur-my-shell]
sigma=30
brightness=0.62
hacks-level=1

[org/gnome/shell/extensions/blur-my-shell/panel]
blur=true

[org/gnome/shell/extensions/blur-my-shell/dash-to-dock]
blur=true
static-blur=true

[org/gnome/shell/extensions/blur-my-shell/overview]
blur=true

[org/gnome/shell/extensions/blur-my-shell/applications]
blur=false

[org/gnome/shell/extensions/user-theme]
name='WhiteSur-Dark'

[org/gnome/shell/extensions/dash-to-dock]
dock-position='BOTTOM'
extend-height=false
dock-fixed=false
autohide=true
intellihide=true
dash-max-icon-size=48
transparency-mode='FIXED'
background-opacity=0.35
running-indicator-style='DOTS'
show-apps-at-top=false
custom-theme-shrink=true
click-action='minimize-or-previews'
