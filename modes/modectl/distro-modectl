#!/usr/bin/env bash
#
# Mode-switcher for the distro: Gaming / AI / Server / Creative / Normal.
# See DESIGN.md §4. Each mode is a profile (modes/modectl/profiles/<mode>.conf)
# applied on top of the same base system — not a separate OS image.
#
# What this script actually does per switch:
#   - sets CPU governor (cpupower) and power profile (powerprofilesctl)
#   - enables/disables/starts/stops the profile's service list
#   - loads/unloads the Ollama model for AI mode (AI_AUTOSTART_USECASE),
#     or unloads it when leaving to another mode (STOP_AI_MODEL=true)
#   - asks for explicit confirmation before disabling a display manager
#     (CONFIRM_DISPLAY_MANAGER_STOP=true) since that can kill an active desktop session
#   - pinning PINNED_APPS to the GNOME favorite-apps dock (best-effort,
#     GNOME-specific, desktop-file IDs unverified — see profiles/*.conf)
#
# What this script deliberately does NOT do (see README.md for why):
#   - Normal mode's theme/dock-position/icon setup — that's a ONE-TIME job,
#     see modes/normal/setup/*.sh, not something to re-apply on every switch
#   - color profile loading for Creative mode (monitor-specific)
#   - GPU performance-state pinning beyond the power-profiles-daemon profile
#
# Usage:
#   distro-modectl switch <gaming|ai|server|creative|normal> [--yes]
#   distro-modectl status
#
# --yes skips the display-manager confirmation prompt — required for any
# non-interactive caller (a future GUI mode-switcher widget, a script, a
# systemd timer). Without it, a non-TTY invocation would hang forever on
# `read`, not fail loudly — that's the worse failure mode, so --yes is
# explicit opt-in rather than auto-detecting non-interactive and skipping.

set -euo pipefail

# Resolve through the /usr/local/bin symlink so profiles/ is found on an
# installed system (build.sh symlinks this script into PATH).
SELF="${BASH_SOURCE[0]}"; [ -L "$SELF" ] && SELF="$(readlink "$SELF")"
PROFILE_DIR="$(cd "$(dirname "$SELF")" && pwd)/profiles"
# Modes root (.../modes) — used by `modes enable` to point a user at a mode's
# setup scripts (/opt/distro/modes/<mode>/setup) on an installed system.
MODES_DIR="$(cd "$(dirname "$SELF")/.." && pwd)"
# Overridable (mirrors GOV_AVAIL_FILE/ENABLED_MODES_FILE below) so the test suite
# can point `status` at a fixture instead of the machine's real /run state.
STATE_FILE="${STATE_FILE:-/run/distro-modectl/current-mode}"
# ALL_MODES is the immutable catalog of modes that CAN exist. VALID_MODES is the
# subset actually enabled on THIS install; it is populated by load_valid_modes()
# from ENABLED_MODES_FILE (see docs/mode-selection-design.md §3.3). 'normal' is
# the always-on base desktop, force-appended by the loader — it is never listed
# in the registry file and is never a selectable/deselectable item.
ALL_MODES=(gaming ai server creative normal)
# Overridable (mirrors GOV_AVAIL_FILE below) so the test suite can point the
# loader at a fixture instead of the real /etc registry.
ENABLED_MODES_FILE="${ENABLED_MODES_FILE:-/etc/refract/enabled-modes}"
VALID_MODES=()
ASSUME_YES=false
# Overridable so the test suite can point apply_cpu_governor at a fixture instead
# of the real sysfs node (see tests/test_modectl.sh).
GOV_AVAIL_FILE="${GOV_AVAIL_FILE:-/sys/devices/system/cpu/cpu0/cpufreq/scaling_available_governors}"

# Populate VALID_MODES from the registry file. Contract (design §3.2/§3.3):
#   - file absent/unreadable -> ALL_MODES (back-compat: pre-feature + existing
#     installs behave exactly as before, all modes valid).
#   - file present -> only the modes it lists are valid; '#' comments, blank
#     lines and unknown tokens are ignored, and 'normal' is ALWAYS force-appended
#     (so a present-but-empty file yields a provably-minimal 'normal'-only system,
#     NOT a silent re-enable of everything).
# Runs BOTH before dispatch AND at source time (tests source with
# DISTRO_MODECTL_SOURCE=1) — safe either way because the absent-file fallback
# needs no /etc access.
load_valid_modes() {
    if [ ! -r "$ENABLED_MODES_FILE" ]; then
        VALID_MODES=("${ALL_MODES[@]}")   # file absent -> keep all five (back-compat)
        return
    fi
    VALID_MODES=()
    local line tok
    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        for tok in $line; do
            [[ " ${ALL_MODES[*]} " == *" $tok "* ]] || continue    # drop unknown tokens
            [[ " ${VALID_MODES[*]} " == *" $tok "* ]] && continue   # dedupe
            VALID_MODES+=("$tok")
        done
    done < "$ENABLED_MODES_FILE"
    [[ " ${VALID_MODES[*]} " == *" normal "* ]] || VALID_MODES+=(normal)   # base always on
}

usage() {
    # Join with IFS='|' in a subshell so the alternatives render as
    # gaming|ai|... — a per-element ${arr[*]// /|} substitution does NOT do
    # this (it only replaces spaces *inside* each element, then joins on the
    # IFS space), so the array must actually be joined with '|'.
    ( IFS='|'; echo "Usage: $(basename "$0") switch <${VALID_MODES[*]}> [--yes] | status | modes <list|status|enable|disable> [mode]" >&2 )
    exit 1
}

require_root_for() {
    if [ "$(id -u)" -ne 0 ]; then
        echo "Re-running with sudo for: $*" >&2
        # Forward --yes across the sudo re-exec: the confirm block runs again
        # on the root pass, and without this the re-exec drops --yes, so a
        # non-interactive `switch server --yes` would abort on the second pass
        # (defeating the whole point of the flag).
        # Mark the re-exec so the root pass skips the per-user steps (theme/dock/
        # AI model) that already ran as the invoking user on this pass — without
        # this they run a SECOND time as the desktop user, reloading the AI model
        # needlessly. --preserve-env carries the marker across sudo's env reset.
        export _REFRACT_REEXEC=1
        if [ "$ASSUME_YES" = "true" ]; then
            sudo --preserve-env=_REFRACT_REEXEC "$0" "$@" --yes
        else
            sudo --preserve-env=_REFRACT_REEXEC "$0" "$@"
        fi
        exit $?
    fi
}

# Resolve the human DESKTOP user we should act on for the per-user steps
# (wallpaper/theme/blur/dock/AI). Invoked with `sudo`, that's $SUDO_USER (root
# has no GUI session); run bare, it's us. Empty => no desktop user (e.g. a pure
# root/SSH shell) so those steps skip instead of running uselessly as root.
target_user() {
    if [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != "root" ]; then
        printf '%s\n' "$SUDO_USER"; return
    fi
    if [ "$(id -u)" -ne 0 ]; then
        # Prefer the name; fall back to the numeric uid when there's no passwd
        # entry (e.g. a live/chroot uid) — checking OUTPUT, not just exit status.
        local n; n="$(id -un 2>/dev/null)"
        if [ -n "$n" ]; then printf '%s\n' "$n"; else id -u; fi
    fi
}

# Run "$@" as the desktop user with their session bus — whether we're already
# that user or root (via sudo). THIS is what makes `sudo distro-modectl switch`
# actually apply the wallpaper/theme/blur/dock/AI-model: those are per-user and
# were silently skipped before, because a root shell has no session bus.
run_as_user() {
    if [ "$(id -u)" -ne 0 ]; then
        # Already a normal user — just make sure a session bus is set, then run.
        DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/$(id -u)/bus}" "$@"
        return
    fi
    # We're root (sudo) — drop to the invoking desktop user + their bus.
    local u uid bus
    u="$(target_user)"; [ -n "$u" ] || return 1
    uid="$(id -u "$u" 2>/dev/null)" || return 1
    bus="${DBUS_SESSION_BUS_ADDRESS:-unix:path=/run/user/${uid}/bus}"
    sudo -u "$u" DBUS_SESSION_BUS_ADDRESS="$bus" XDG_RUNTIME_DIR="/run/user/${uid}" "$@"
}

# The config dir a run_as_user'd command ACTUALLY sees — mirrors run_as_user's
# two branches, so a guard on someone's per-user state tests the same path the
# guarded command reads/writes. As a normal user the command inherits our env; as
# root it goes through `sudo -u`, whose env_reset drops XDG_CONFIG_HOME and points
# HOME at the target user's passwd home. Testing OUR $HOME in the root case would
# test /root/.config — under the documented `sudo distro-modectl switch ...` that
# is a path nothing ever creates. Empty output/non-zero => could not resolve.
user_config_dir() {
    if [ "$(id -u)" -ne 0 ]; then
        printf '%s\n' "${XDG_CONFIG_HOME:-$HOME/.config}"
        return 0
    fi
    # `|| var=""`: target_user/getent exit non-zero when there is no desktop user
    # / no passwd entry, and a bare assignment would trip `set -e`.
    local u="" home=""
    u="$(target_user)" || u=""
    [ -n "$u" ] || return 1
    home="$(getent passwd "$u" 2>/dev/null | cut -d: -f6)" || home=""
    [ -n "$home" ] || return 1
    printf '%s\n' "$home/.config"
}

apply_cpu_governor() {
    local gov="$1"
    if ! command -v cpupower >/dev/null 2>&1; then
        echo "WARNING: cpupower not installed — skipping CPU governor change (apt install linux-tools-common linux-tools-\$(uname -r))" >&2
        return 0
    fi
    # Adapt the requested governor to what this CPU's cpufreq driver actually
    # offers. Intel's intel_pstate (active mode) — what a modern ThinkPad/laptop
    # runs — exposes ONLY 'powersave' and 'performance', NOT schedutil/ondemand/
    # conservative (those are acpi-cpufreq). Requesting an unavailable governor
    # makes cpupower fail and print a scary WARNING on the *default* Normal/AI
    # modes. So map intent -> an available governor instead of failing:
    #   * performance stays performance
    #   * everything balanced/efficiency (schedutil/ondemand/conservative/powersave)
    #     -> 'powersave' on intel_pstate (its balanced governor; the real per-mode
    #     balancing is done by power-profiles-daemon's EPP, set separately).
    local avail=""
    [ -r "$GOV_AVAIL_FILE" ] && avail="$(cat "$GOV_AVAIL_FILE" 2>/dev/null)"
    if [ -n "$avail" ] && ! printf ' %s ' "$avail" | grep -q " $gov "; then
        local mapped=""
        case "$gov" in
            performance) printf ' %s ' "$avail" | grep -q " performance " && mapped="performance" ;;
            *)           printf ' %s ' "$avail" | grep -q " powersave "   && mapped="powersave"   ;;
        esac
        # Last resort: first governor the driver lists.
        [ -n "$mapped" ] || mapped="$(printf '%s\n' "$avail" | awk '{print $1; exit}')"
        if [ -n "$mapped" ] && [ "$mapped" != "$gov" ]; then
            echo "Note: CPU governor '$gov' isn't offered by this CPU (intel_pstate?); using '$mapped'." >&2
            gov="$mapped"
        fi
    fi
    cpupower frequency-set -g "$gov" >/dev/null || echo "WARNING: failed to set CPU governor to $gov" >&2
}

apply_power_profile() {
    local profile="$1"
    if command -v powerprofilesctl >/dev/null 2>&1; then
        powerprofilesctl set "$profile" || echo "WARNING: failed to set power profile to $profile" >&2
    else
        echo "WARNING: powerprofilesctl not installed — skipping power profile change (apt install power-profiles-daemon)" >&2
    fi
}

# Best-effort GPU performance-state control. "max" pins the Nvidia GPU to its
# top performance state for Gaming/Creative; "auto" returns it to adaptive for
# the other modes. Prefers nvidia-smi (works headless AND under Wayland — the
# whole point, since nvidia-settings/GpuPowerMizerMode needs an X server) and
# additionally sets GpuPowerMizerMode when a usable X DISPLAY is present.
# nvidia-smi clock locks don't persist across reboot, which is fine: this
# re-applies on every mode switch. ALL of this is web-verified (nvidia-smi
# man page, NVIDIA forums) but UNVERIFIED on real hardware — no GPU yet.
apply_gpu_perf() {
    local want="$1"
    command -v nvidia-smi >/dev/null 2>&1 || return 0   # no Nvidia GPU/driver -> nothing to do
    if [ "$want" = "max" ]; then
        sudo nvidia-smi -pm 1 >/dev/null 2>&1 || echo "WARNING: could not enable GPU persistence mode" >&2
        # Lock the graphics clock to the GPU's max supported value (headless-safe).
        # Guard the substitution: under `set -euo pipefail` a failing nvidia-smi
        # here would otherwise abort the whole mode switch.
        local maxclk=""
        # `|| true` (not `|| maxclk=""`): the awk early-exit closes the pipe and
        # nvidia-smi dies with SIGPIPE (141), which under `set -o pipefail` makes
        # the pipeline non-zero AFTER the value was already captured — overwriting
        # it with "" would silently skip the clock lock. The assignment already
        # holds awk's stdout, so just swallow the pipe status.
        maxclk=$(nvidia-smi -q -d SUPPORTED_CLOCKS 2>/dev/null | awk '/Graphics/{print $3; exit}') || true
        if [ -n "${maxclk:-}" ]; then
            # Both bounds = maxclk actually PINS the clock; a min of 0 would let
            # the GPU keep downclocking, defeating the point of the lock.
            sudo nvidia-smi -lgc "${maxclk},${maxclk}" >/dev/null 2>&1 || echo "WARNING: could not lock GPU clocks" >&2
        fi
        if [ -n "${DISPLAY:-}" ] && command -v nvidia-settings >/dev/null 2>&1; then
            nvidia-settings -a '[gpu:0]/GpuPowerMizerMode=1' >/dev/null 2>&1 || true   # X11 only; best-effort
        fi
        echo "GPU: pinned to max performance (best-effort — verify with nvidia-smi -q -d PERFORMANCE)."
    else
        sudo nvidia-smi -rgc >/dev/null 2>&1 || true   # reset GPU clocks
        sudo nvidia-smi -rmc >/dev/null 2>&1 || true   # reset memory clocks
        if [ -n "${DISPLAY:-}" ] && command -v nvidia-settings >/dev/null 2>&1; then
            nvidia-settings -a '[gpu:0]/GpuPowerMizerMode=0' >/dev/null 2>&1 || true
        fi
    fi
}

apply_services() {
    local -n enable_list=$1
    local -n disable_list=$2
    for svc in "${enable_list[@]:-}"; do
        [ -z "$svc" ] && continue
        if systemctl list-unit-files "${svc}*" 2>/dev/null | grep -q "^${svc}"; then
            systemctl enable --now "$svc" 2>/dev/null || echo "WARNING: failed to enable/start $svc" >&2
        else
            echo "NOTE: $svc not installed — skipping (this mode expects it; install it for full functionality)" >&2
        fi
    done
    for svc in "${disable_list[@]:-}"; do
        [ -z "$svc" ] && continue
        # Display managers: plain `disable` (NOT --now) so the effect is deferred
        # to next boot, matching the confirm prompt + profile NOTES wording. Using
        # --now here would tear down the ACTIVE graphical session immediately
        # (Xorg is owned by gdm under WaylandEnable=false), losing unsaved work.
        if [[ "$svc" =~ ^(gdm|gdm3|sddm|lightdm)$ ]]; then
            systemctl disable "$svc" 2>/dev/null || true
        else
            systemctl disable --now "$svc" 2>/dev/null || true
        fi
    done
}

# AI-model handling runs as the USER, so this is called BEFORE the sudo re-exec.
# Ollama itself is a system service (user 'ollama' on :11434), but distro-ai-model
# keeps its per-user tier/use-case state in the desktop user's ~/.config/refract-ai
# and reaches Ollama over localhost (the user is in the 'ollama' group) — so it
# must run as that user, not root. Best-effort: a failure warns but never aborts
# the mode switch (the system settings still apply).
apply_ai_model() {
    # distro-ai-model's config lives in the user's home, so run these as the
    # desktop user via run_as_user — which works whether invoked bare OR via sudo
    # (previously this early-returned when id==0, so `sudo distro-modectl switch
    # ai` never loaded a model). Skips entirely when there's no desktop user.
    [ -n "$(target_user)" ] || return 0
    if [ "${STOP_AI_MODEL:-false}" = "true" ]; then
        command -v distro-ai-model >/dev/null 2>&1 && run_as_user distro-ai-model unload >/dev/null 2>&1 || true
    fi
    if [ -n "${AI_AUTOSTART_USECASE:-}" ]; then
        # First AI-mode entry: auto-detect the hardware tier so the models that
        # fit this box are what get loaded/preloaded. Failure-tolerant (the
        # datacenter guard exits non-zero to route server-class GPUs to Server
        # mode — that must not break the mode switch).
        #
        # The "first entry" test MUST read the tier file in the desktop user's
        # config dir — the same context run_as_user runs detect-tier in — not
        # ${XDG_CONFIG_HOME:-$HOME/.config} of THIS process: under `sudo
        # distro-modectl switch ai` sudo's env_reset makes that /root/.config,
        # which nothing ever writes, so the guard would always pass and
        # detect-tier (--yes leaves DO_WRITE=1) would clobber a forced --tier and
        # the user's image choice on EVERY ai switch. Unresolvable config dir =>
        # skip: not auto-detecting is recoverable (distro-ai-detect-tier by hand),
        # overwriting someone's explicit tier is not.
        local cfg_dir=""
        cfg_dir="$(user_config_dir)" || cfg_dir=""
        if command -v distro-ai-detect-tier >/dev/null 2>&1 \
           && [ -n "$cfg_dir" ] && [ ! -f "$cfg_dir/refract-ai/tier" ]; then
            run_as_user distro-ai-detect-tier --yes >/dev/null 2>&1 \
                || echo "Note: AI hardware-tier auto-detect didn't complete (server-class GPU? run distro-ai-detect-tier). Using defaults." >&2
        fi
        if command -v distro-ai-model >/dev/null 2>&1; then
            run_as_user distro-ai-model use "$AI_AUTOSTART_USECASE" \
                || echo "WARNING: distro-ai-model failed to load the '$AI_AUTOSTART_USECASE' model — the mode still switched, but no model is loaded. Check: distro-ai-model status" >&2
        else
            echo "WARNING: distro-ai-model not found — install modes/ai/bin/distro-ai-model (and run modes/ai/setup/) to auto-load a model in AI mode." >&2
        fi
    fi
}

apply_pinned_apps() {
    local -n apps=$1
    [ ${#apps[@]} -eq 0 ] && return 0
    if ! command -v gsettings >/dev/null 2>&1; then
        echo "NOTE: gsettings not found — skipping favorite-apps pin (GNOME-only feature)." >&2
        return 0
    fi
    if [ -z "$(target_user)" ]; then
        echo "NOTE: no desktop user — favorite-apps pin needs a graphical login, not a pure root/SSH shell. Skipping." >&2
        return 0
    fi
    local joined
    joined=$(printf "'%s', " "${apps[@]}")
    joined="[${joined%, }]"
    echo "Pinning to dock (GNOME favorite-apps, desktop-file IDs unverified): ${apps[*]}"
    run_as_user gsettings set org.gnome.shell favorite-apps "$joined" || echo "WARNING: gsettings call failed — desktop-file IDs may not match what's actually installed." >&2
}

apply_theme() {
    # Per-mode desktop look. The BASE look is macOS-style (WhiteSur GTK/icons +
    # bottom dock), baked into the image as the default; here we (re)assert it on
    # every switch so it survives mode changes instead of reverting to Ubuntu's
    # Yaru, swap the per-mode WALLPAPER, and toggle the frosted "liquid glass"
    # blur — ON for Normal only, OFF elsewhere (real-time blur is GPU-heavy, and
    # Gaming/AI/Creative want every GPU cycle). GNOME-only, needs the invoking
    # user's session bus, so it runs pre-sudo like apply_pinned_apps.
    command -v gsettings >/dev/null 2>&1 || return 0
    if [ -z "$(target_user)" ]; then
        echo "NOTE: no desktop user — skipping per-mode theme (needs a graphical login)." >&2
        return 0
    fi
    if [ -n "${WALLPAPER:-}" ] && [ -f "$WALLPAPER" ]; then
        run_as_user gsettings set org.gnome.desktop.background picture-uri "file://$WALLPAPER" 2>/dev/null || true
        run_as_user gsettings set org.gnome.desktop.background picture-uri-dark "file://$WALLPAPER" 2>/dev/null || true
        run_as_user gsettings set org.gnome.desktop.background picture-options 'zoom' 2>/dev/null || true
    fi
    run_as_user gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
    # Keep the macOS (WhiteSur) look consistent across ALL modes — do not revert
    # to Yaru. WhiteSur-Dark ships system-wide via iso 0300-macos-look.chroot.
    run_as_user gsettings set org.gnome.desktop.interface gtk-theme 'WhiteSur-Dark' 2>/dev/null || true
    run_as_user gsettings set org.gnome.desktop.interface icon-theme 'WhiteSur-dark' 2>/dev/null || true
    run_as_user gsettings set org.gnome.shell.extensions.user-theme name 'WhiteSur-Dark' 2>/dev/null || true
    # Liquid glass (frosted blur via the Blur-my-Shell extension): Normal ONLY.
    if command -v gnome-extensions >/dev/null 2>&1; then
        if [ "${LIQUID_GLASS:-false}" = "true" ]; then
            run_as_user gnome-extensions enable blur-my-shell@aunetx 2>/dev/null \
                || echo "NOTE: could not enable Blur-my-Shell (install it / new-session needed) — glass off." >&2
        else
            run_as_user gnome-extensions disable blur-my-shell@aunetx 2>/dev/null || true
        fi
    fi
    echo "Applied ${MODE_NAME} look: macOS-style (WhiteSur-Dark)${WALLPAPER:+ + wallpaper}, liquid-glass=${LIQUID_GLASS:-false}."
}

confirm_or_abort() {
    local prompt="$1"
    if [ "$ASSUME_YES" = "true" ]; then
        echo "$prompt [auto-confirmed via --yes]"
        return 0
    fi
    if [ ! -t 0 ]; then
        echo "Refusing to prompt on a non-interactive stdin without --yes: $prompt" >&2
        exit 1
    fi
    read -r -p "$prompt [y/N] " reply
    case "$reply" in [yY]|[yY][eE][sS]) ;; *) echo "Aborted."; exit 1 ;; esac
}

do_switch() {
    local mode="$1"
    # Membership guard against the now-dynamic VALID_MODES. A mode that is a
    # KNOWN mode but simply not enabled on this install gets a targeted pointer
    # at `modes enable <mode>` (design §5) instead of the bare usage; a genuinely
    # unknown token still falls through to usage().
    if [[ " ${VALID_MODES[*]} " != *" $mode "* ]]; then
        if [[ " ${ALL_MODES[*]} " == *" $mode "* ]]; then
            echo "Mode '$mode' is not enabled on this system." >&2
            echo "Enable it with:  $(basename "$0") modes enable $mode" >&2
            exit 1
        fi
        usage
    fi

    local profile_file="$PROFILE_DIR/${mode}.conf"
    [ -f "$profile_file" ] || { echo "No profile found at $profile_file" >&2; exit 1; }

    # shellcheck disable=SC1090
    source "$profile_file"

    echo "Switching to: $MODE_NAME mode"
    [ -n "${NOTES:-}" ] && echo "Note: $NOTES"

    if [ "${CONFIRM_DISPLAY_MANAGER_STOP:-false}" = "true" ]; then
        for svc in "${DISABLE_SERVICES[@]:-}"; do
            if [[ "$svc" =~ ^(gdm|gdm3|sddm|lightdm)$ ]]; then
                confirm_or_abort "This will disable the display manager ($svc) — your desktop session will not restart automatically next boot. Continue?"
                # Confirmed once — forward --yes across the sudo re-exec so the
                # root pass doesn't prompt a second time.
                ASSUME_YES=true
                break
            fi
        done
    fi

    # Run before the sudo re-exec below: gsettings needs the invoking user's
    # own session bus, and distro-ai-model's config is per-user, not root's.
    # Skipped on the root re-exec pass ($_REFRACT_REEXEC set by require_root_for)
    # so they run EXACTLY ONCE — but still run when invoked directly via `sudo`
    # (no marker), which is the case the id!=0 guard used to wrongly skip.
    if [ -z "${_REFRACT_REEXEC:-}" ]; then
        apply_pinned_apps PINNED_APPS
        apply_theme
        apply_ai_model
    fi

    require_root_for switch "$mode"

    apply_cpu_governor "$CPU_GOVERNOR"
    apply_power_profile "$POWER_PROFILE"
    apply_gpu_perf "${GPU_PERF:-auto}"
    apply_services ENABLE_SERVICES DISABLE_SERVICES

    mkdir -p "$(dirname "$STATE_FILE")"
    echo "$mode" > "$STATE_FILE"

    echo "Now in: $MODE_NAME mode"
}

do_status() {
    if [ -f "$STATE_FILE" ]; then
        echo "Current mode: $(cat "$STATE_FILE")"
    else
        echo "Current mode: unknown (no mode switch recorded yet)"
    fi
    if command -v powerprofilesctl >/dev/null 2>&1; then
        echo "Power profile: $(powerprofilesctl get 2>/dev/null || echo unknown)"
    fi
    return 0
}

# ---------------------------------------------------------------------------
# `modes` subcommand — inspect and mutate the enabled-mode registry at runtime.
# There is no post-install first-boot wizard (gnome-initial-setup is purged and
# masked), so this is the runtime lever for the install-time "what is this
# machine for?" choice (design §5). SOFT level only: disabling a mode hides it
# from the switcher but leaves its files under /opt/distro — provable absence is
# a HARD, mode-omitted build (design §2/§4), never a runtime toggle.
# ---------------------------------------------------------------------------

# The optional modes of THIS build: ALL_MODES minus the always-on 'normal'.
# Derived at runtime and never spelled out in a message, because a HARD,
# mode-omitted build rewrites the shipped copy's ALL_MODES=(...) (iso/build.sh):
# a literal list would advertise modes whose files this image doesn't contain.
optional_modes() {
    local -n _out=$1
    local m
    _out=()
    for m in "${ALL_MODES[@]}"; do
        [ "$m" = "normal" ] || _out+=("$m")
    done
}

# Validate an `enable`/`disable` target: must be a known OPTIONAL mode. 'normal'
# is the always-on base and is rejected as a target; unknown tokens are rejected.
require_optional_mode() {
    local mode="$1" verb="$2"
    local -a opts=(); optional_modes opts
    if [ "${#opts[@]}" -eq 0 ]; then
        # An all-optional-modes-omitted build: nothing to enable or disable.
        echo "This build ships no optional modes — 'normal' is the only mode." >&2
        exit 1
    fi
    if [ -z "$mode" ]; then
        # Joined with IFS='|' in a subshell, like usage() — see the note there.
        echo "Usage: $(basename "$0") modes $verb <$( IFS='|'; echo "${opts[*]}" )>" >&2
        exit 1
    fi
    if [ "$mode" = "normal" ]; then
        echo "'normal' is the always-on base desktop — it is never enabled or disabled." >&2
        exit 1
    fi
    if [[ " ${ALL_MODES[*]} " != *" $mode "* ]]; then
        echo "Unknown mode '$mode'. Optional modes are: ${opts[*]}." >&2
        exit 1
    fi
}

# Rewrite ENABLED_MODES_FILE from the currently-enabled optional set with the
# target added (op=enable) or removed (op=disable). Iterates the optional modes in
# catalog order for a stable, deduped result; 'normal' is never written (the
# loader force-appends it).
# World-readable (0644) is mandatory: load_valid_modes runs both pre- and
# post-sudo, so a root-only file would make the two passes disagree (design §3.3).
rewrite_registry() {
    local op="$1" target="$2" m
    local -a keep=() opts=()
    optional_modes opts
    for m in "${opts[@]}"; do
        if [ "$m" = "$target" ]; then
            [ "$op" = "enable" ] && keep+=("$m")
            continue
        fi
        [[ " ${VALID_MODES[*]} " == *" $m "* ]] && keep+=("$m")
    done
    mkdir -p "$(dirname "$ENABLED_MODES_FILE")"
    {
        echo "# Refract OS — enabled optional modes (managed by 'distro-modectl modes')."
        echo "# One mode per line. Valid optional modes: ${opts[*]}."
        echo "# 'normal' is the always-on base desktop and is never listed here."
        if [ "${#keep[@]}" -gt 0 ]; then
            printf '%s\n' "${keep[@]}"
        fi
    } > "$ENABLED_MODES_FILE"
    chmod 0644 "$ENABLED_MODES_FILE" 2>/dev/null || true
}

# Run a mode's on-demand setup after enabling it. AI has a dedicated entrypoint
# (distro-ai-setup) which REFUSES root and keeps per-user state, so it runs as
# the desktop user via run_as_user with --install --yes (non-interactive so a
# non-TTY caller never hangs). Modes without a single CLI entrypoint print how
# to run their numbered setup scripts instead of auto-installing heavy payloads.
run_mode_setup() {
    local mode="$1"
    case "$mode" in
        ai)
            if command -v distro-ai-setup >/dev/null 2>&1; then
                echo "Running AI setup as the desktop user (distro-ai-setup refuses root)..."
                run_as_user distro-ai-setup --install --yes \
                    || echo "WARNING: distro-ai-setup did not complete — 'ai' is enabled in the registry; re-run it as your desktop user: distro-ai-setup --install" >&2
            else
                echo "'ai' enabled. Install the local AI stack as your desktop user: distro-ai-setup --install"
            fi
            ;;
        gaming|creative)
            # Gaming/Creative setup scripts are USER scripts: they call `sudo`
            # internally for the privileged steps and add the DESKTOP user to
            # groups via "$USER" (e.g. gaming's 06 runs `sudo usermod -aG gamemode
            # "$USER"`). Run them with BARE `bash` as your normal user — under
            # `sudo bash` $USER resolves to root, so the group-add would target
            # root instead of the desktop user.
            local setup_dir="$MODES_DIR/$mode/setup"
            echo "'$mode' enabled. Install its apps by running its setup scripts as your normal user, in order:"
            if [ -d "$setup_dir" ]; then
                echo "  for s in \"$setup_dir\"/[0-9]*.sh; do bash \"\$s\"; done"
            else
                echo "  for s in /opt/distro/modes/$mode/setup/[0-9]*.sh; do bash \"\$s\"; done"
            fi
            ;;
        *)
            # Server (and any future system-daemon mode): setup scripts install
            # system services, so run them as root via sudo.
            local setup_dir="$MODES_DIR/$mode/setup"
            echo "'$mode' enabled. Install its apps by running its setup scripts as root, in order:"
            if [ -d "$setup_dir" ]; then
                echo "  for s in \"$setup_dir\"/[0-9]*.sh; do sudo bash \"\$s\"; done"
            else
                echo "  for s in /opt/distro/modes/$mode/setup/[0-9]*.sh; do sudo bash \"\$s\"; done"
            fi
            ;;
    esac
}

modes_enable() {
    local mode="$1"
    require_optional_mode "$mode" enable
    # ALL_MODES membership is not enough: a HARD per-install removal
    # (distro-apply-mode-selection with APPLY_HARD_REMOVAL=1) deletes
    # profiles/<mode>.conf but leaves ALL_MODES alone, so without this we would
    # record the mode in the registry and report success for a mode `switch` can
    # never resolve ("No profile found"). Checked before require_root_for so it
    # fails without a sudo prompt.
    if [ ! -f "$PROFILE_DIR/$mode.conf" ]; then
        echo "Mode '$mode' cannot be enabled: its profile is missing ($PROFILE_DIR/$mode.conf)." >&2
        echo "This install does not ship '$mode' — only a build that includes it can enable it." >&2
        exit 1
    fi
    # Writing under /etc needs root; the re-exec carries `modes enable <mode>`.
    require_root_for modes enable "$mode"
    # load_valid_modes already ran this pass, so VALID_MODES reflects the file.
    local already=no
    [[ " ${VALID_MODES[*]} " == *" $mode "* ]] && already=yes
    rewrite_registry enable "$mode"
    if [ "$already" = "yes" ]; then
        echo "Mode '$mode' was already enabled in $ENABLED_MODES_FILE."
    else
        echo "Enabled '$mode' (recorded in $ENABLED_MODES_FILE)."
    fi
    run_mode_setup "$mode"
}

modes_disable() {
    local mode="$1"
    require_optional_mode "$mode" disable
    require_root_for modes disable "$mode"
    if [[ " ${VALID_MODES[*]} " != *" $mode "* ]]; then
        echo "Mode '$mode' is not currently enabled — nothing to do."
        return 0
    fi
    rewrite_registry disable "$mode"
    echo "Disabled '$mode'. This is a SOFT hide: its files remain under /opt/distro/modes/$mode."
    echo "Provable absence requires a HARD, mode-omitted build (see docs/mode-selection-design.md §2/§4)."
}

do_modes_status() {
    echo "Enabled modes:   ${VALID_MODES[*]}"
    echo "Available modes: ${ALL_MODES[*]}"
    local m
    for m in "${ALL_MODES[@]}"; do
        [ "$m" = "normal" ] && continue
        if [[ " ${VALID_MODES[*]} " == *" $m "* ]]; then
            echo "  [x] $m"
        else
            echo "  [ ] $m  (enable: $(basename "$0") modes enable $m)"
        fi
    done
    echo "  [x] normal  (always-on base desktop)"
    if [ -r "$ENABLED_MODES_FILE" ]; then
        echo "Registry: $ENABLED_MODES_FILE"
    else
        echo "Registry: $ENABLED_MODES_FILE (absent — all modes enabled by default)"
    fi
}

do_modes() {
    local verb="${1:-list}"
    case "$verb" in
        list|status) do_modes_status ;;
        enable)      modes_enable "${2:-}" ;;
        disable)     modes_disable "${2:-}" ;;
        *)
            echo "Usage: $(basename "$0") modes <list|status|enable <mode>|disable <mode>>" >&2
            exit 1
            ;;
    esac
}

# Populate VALID_MODES from the registry before anything dispatches (and at
# source time for the unit tests) — both real consumers, usage() and do_switch(),
# read the array by name, so repopulating it here gives soft-hide + enforcement
# for free.
load_valid_modes

# Dispatch — skipped when the script is SOURCED for unit tests. The suite sets
# DISTRO_MODECTL_SOURCE=1 to load the functions (e.g. apply_cpu_governor) and
# exercise them directly without triggering a real mode switch.
if [ "${DISTRO_MODECTL_SOURCE:-}" != "1" ]; then
case "${1:-}" in
    switch)
        [ $# -ge 2 ] || usage
        mode="$2"
        shift 2
        for arg in "$@"; do
            [ "$arg" = "--yes" ] && ASSUME_YES=true
        done
        do_switch "$mode"
        ;;
    status) do_status ;;
    modes)
        shift
        do_modes "$@"
        ;;
    *) usage ;;
esac
fi
