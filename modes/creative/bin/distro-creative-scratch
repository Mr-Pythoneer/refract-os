#!/usr/bin/env bash
#
# Detects the fastest local writable mount (preferring genuine NVMe over
# any other non-rotational storage, per DESIGN.md §4: "scratch-disk/cache
# paths defaulting to the fastest local NVMe") and sets up a scratch
# directory there for Creative-mode render/cache use.
#
# Detection method: `df -l` (local filesystems only, so network mounts are
# excluded) with --output to select columns gives every mounted filesystem +
# free space; `lsblk -ndo ROTA,NAME` on each mount's backing device tells us whether
# it's rotational (HDD, ROTA=1) or not (SSD/NVMe, ROTA=0). Among non-rotational
# candidates, devices named nvme* are preferred; if none exist, any
# non-rotational device is used as a documented fallback rather than failing.
#
# Usage:
#   distro-creative-scratch detect          -- print the best path, do nothing else
#   distro-creative-scratch setup           -- detect + create scratch dir +
#                                               write /etc/profile.d env var +
#                                               best-effort Blender preference

set -euo pipefail

SCRATCH_DIRNAME="refract-creative-scratch"
PROFILE_D_FILE="/etc/profile.d/refract-creative-scratch.sh"

detect_best_mount() {
    if ! command -v df >/dev/null 2>&1 || ! command -v lsblk >/dev/null 2>&1; then
        echo "distro-creative-scratch: requires df and lsblk" >&2
        return 1
    fi

    # Do NOT add -P here: GNU coreutils df treats -P/--portability and --output
    # as mutually exclusive, so `df -lP --output=...` errors to stderr and emits
    # nothing — which (swallowed by 2>/dev/null) silently collapsed this whole
    # detection to the /var/tmp fallback on every Ubuntu box. Capture df
    # separately so a future incompatibility surfaces loudly instead of degrading
    # silently.
    local df_out
    df_out="$(df -l --output=source,target,avail 2>/dev/null | tail -n +2)" || true
    if [ -z "$df_out" ]; then
        echo "distro-creative-scratch: df produced no usable output -- cannot detect mounts, falling back to /var/tmp" >&2
        printf '%s\n' "/var/tmp"
        return 0
    fi

    local best_path="" best_avail=-1 best_is_nvme=0

    while read -r source target avail; do
        [ "$target" = "/boot" ] || [ "$target" = "/boot/efi" ] && continue
        case "$source" in
            /dev/*) ;;
            *) continue ;;  # skip tmpfs/overlay/etc. df -l should already exclude these, this is a second guard
        esac

        local rota name
        rota="$(lsblk -ndo ROTA "$source" 2>/dev/null | head -n1 | tr -d '[:space:]')"
        name="$(lsblk -ndo NAME "$source" 2>/dev/null | head -n1 | tr -d '[:space:]')"
        [ "$rota" = "0" ] || continue   # rotational or unknown -- skip, only want SSD/NVMe

        local is_nvme=0
        case "$name" in
            nvme*) is_nvme=1 ;;
        esac

        # Prefer any nvme candidate over any non-nvme candidate, regardless of
        # free space; within the same tier, prefer more free space.
        if [ "$is_nvme" -gt "$best_is_nvme" ] || { [ "$is_nvme" -eq "$best_is_nvme" ] && [ "$avail" -gt "$best_avail" ]; }; then
            best_path="$target"
            best_avail="$avail"
            best_is_nvme="$is_nvme"
        fi
    done <<< "$df_out"

    if [ -z "$best_path" ]; then
        echo "distro-creative-scratch: no non-rotational local mount found -- falling back to /var/tmp (rotational disk or undetectable storage)" >&2
        best_path="/var/tmp"
    elif [ "$best_is_nvme" -eq 0 ]; then
        echo "distro-creative-scratch: no NVMe device found, using best available non-rotational mount instead ($best_path)" >&2
    fi

    printf '%s\n' "$best_path"
}

case "${1:-}" in
    detect)
        detect_best_mount
        ;;
    setup)
        # setup does root-only work (mkdir/chmod on a mount root, writing
        # $PROFILE_D_FILE under /etc). Guard up front so an unprivileged run
        # fails with a clear message instead of dying mid-way on a raw
        # 'permission denied' under set -e. 'detect' is unprivileged by design
        # and intentionally has NO such guard.
        if [ "$(id -u)" -ne 0 ]; then
            echo "distro-creative-scratch setup: must be run as root (creates a system scratch dir and writes $PROFILE_D_FILE)." >&2
            echo "Re-run with: sudo $(basename "$0") setup" >&2
            exit 1
        fi

        best="$(detect_best_mount)"
        scratch_dir="$best/$SCRATCH_DIRNAME"

        mkdir -p "$scratch_dir"
        chmod 1777 "$scratch_dir"   # sticky bit, shared scratch space for any user

        cat > "$PROFILE_D_FILE" <<EOF
# Written by distro-creative-scratch -- Creative mode's render/cache scratch
# directory, pointed at the fastest local NVMe (or best available non-rotational
# mount) detected at setup time. Re-run 'distro-creative-scratch setup' after
# adding/removing storage if this should be re-evaluated.
export REFRACT_SCRATCH_DIR="$scratch_dir"
EOF
        chmod 644 "$PROFILE_D_FILE"

        echo "Scratch directory: $scratch_dir"
        echo "REFRACT_SCRATCH_DIR exported via $PROFILE_D_FILE (takes effect in new login sessions)"

        # Blender ships as the Flatpak org.blender.Blender on this distro (see
        # modes/creative/setup/02-install-blender.sh) — there is NO `blender` in
        # PATH — so also detect the Flatpak and drive it via `flatpak run`. The
        # preference is per-user, so when we're root (setup writes /etc/profile.d)
        # run Blender as the invoking desktop user so it lands in THEIR home.
        blender_cmd=""
        if command -v blender >/dev/null 2>&1; then
            blender_cmd="blender"
        elif command -v flatpak >/dev/null 2>&1 && flatpak info org.blender.Blender >/dev/null 2>&1; then
            blender_cmd="flatpak run org.blender.Blender"
        fi

        if [ -n "$blender_cmd" ]; then
            echo "Setting Blender's temporary-files preference to \$REFRACT_SCRATCH_DIR..."
            blender_pref="import bpy
bpy.context.preferences.filepaths.temporary_directory = '$scratch_dir'
bpy.ops.wm.save_userpref()"
            if [ "$(id -u)" -eq 0 ] && [ -n "${SUDO_USER:-}" ] && [ "$SUDO_USER" != root ]; then
                run_blender() { sudo -u "$SUDO_USER" $blender_cmd "$@"; }
            else
                run_blender() { $blender_cmd "$@"; }
            fi
            if run_blender --background --python-expr "$blender_pref" >/dev/null 2>&1; then
                echo "Blender preference set."
            else
                echo "Blender preference update failed (non-fatal) -- set it manually:" >&2
                echo "  Edit > Preferences > File Paths > Temporary Files = $scratch_dir" >&2
            fi
        else
            echo "Blender not installed yet -- once it is, set Edit > Preferences > File Paths >"
            echo "Temporary Files = \$REFRACT_SCRATCH_DIR manually, or re-run this script after installing it."
        fi

        echo
        echo "DaVinci Resolve has no scriptable/CLI way to set its cache/working-folder"
        echo "paths (it's a per-project setting stored in Resolve's project database, GUI-only)"
        echo "-- not automated here. Set it manually per project:"
        echo "  Project Settings > General > Working Folders / Cache Files > $scratch_dir"
        echo
        echo "ffmpeg has no dedicated scratch-dir setting either; if you want render"
        echo "intermediates to land on this disk, pass output paths under \$REFRACT_SCRATCH_DIR explicitly."
        ;;
    *)
        echo "Usage: $(basename "$0") detect | setup" >&2
        exit 1
        ;;
esac
