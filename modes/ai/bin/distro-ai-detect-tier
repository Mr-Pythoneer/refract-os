#!/usr/bin/env bash
#
# Auto-detects the AI-model TIER for this machine and records it (plus the
# laptop power PROFILE and the image-gen choice) into ~/.config/refract-ai so
# distro-ai-model / 02-preload-models.sh preload models that fit the hardware.
#
# What it detects (all cross-vendor, no root needed):
#   VRAM  - Nvidia via nvidia-smi; AMD (and APU carveout) via
#           /sys/class/drm/card*/device/mem_info_vram_total. MULTI-GPU: sums
#           VRAM across HOMOGENEOUS same-name cards (Ollama pools
#           same-vendor cards via layer-split); mixed vendors are NOT pooled.
#   Intel - Arc via lspci + vulkaninfo --summary, ONLY when the probes above found
#           no VRAM; Ollama's Vulkan backend (OLLAMA_VULKAN=1) is turned on for it.
#           An INTEGRATED Arc has no VRAM of its own (it shares LPDDR system RAM),
#           so it's tiered by usable system RAM, not VRAM. A DISCRETE Arc (A770,
#           B580, ...) is told apart by its PCI address (an iGPU is always 00:02.x)
#           and gets a floored 'entry' tier: there is NO VRAM probe for Intel dGPUs
#           (mem_info_vram_total is amdgpu-only), and this does not fake one — pass
#           --tier for a bigger card.
#   RAM   - /proc/meminfo MemTotal.
#   form  - laptop vs desktop via DMI chassis_type + battery presence.
#
# VRAM(GiB) -> tier:  <5 cpu | 5-11 entry | 11-20 mid | 20-30 high |
#                     30-45 max (RTX 5090 32GB) | >=45 ultra (48-96GB workstation)
#   (cpu tier = no usable dedicated GPU: CPU inference, <=3B models.)
#   'ultra' = 48-96GB-class workstation cards (RTX PRO 6000 96GB, RTX 6000 Ada
#   48GB, W7900 48GB, or 2x homogeneous pooled). DATACENTER GPUs
#   (A100/H100/H200/B200/MI300X/Gaudi/Grace) are NOT a desktop tier — this
#   routes them to Server mode's headless serving path instead.
#
# PROFILE (which model variant distro-ai-model loads by default):
#   desktop -> power (best models). laptop -> you choose:
#     efficiency (the lightest model a use-case offers: fastest, least battery)
#     | balance | power (== desktop: the best models the tier fits).
#
# IMAGE (which ComfyUI image model to preload): you pick from what the tier
#   supports, or none.
#
# Detection inputs are overridable by env (REFRACT_VRAM_MIB, REFRACT_GPU_LIST
# ["mib:name;mib:name"], REFRACT_IS_LAPTOP, REFRACT_RAM_MB, REFRACT_ALLOW_
# DATACENTER, REFRACT_LSPCI, REFRACT_VULKAN_SUMMARY, NVIDIA_SMI, SYS_DRM_ROOT,
# SYS_DMI_CHASSIS, SYS_POWER_ROOT, PROC_MEMINFO) so this is testable without the
# real hardware.
#
# Usage:
#   distro-ai-detect-tier                 # detect; ask (laptop profile + image) if a TTY; write config
#   distro-ai-detect-tier --print         # detect + print only; write nothing, ask nothing
#   distro-ai-detect-tier --yes           # detect + write with defaults; ask nothing (setup wizard / non-TTY)
#   distro-ai-detect-tier --tier ultra --profile power --image flux-dev   # force any field

set -euo pipefail

SELF="${BASH_SOURCE[0]}"; [ -L "$SELF" ] && SELF="$(readlink "$SELF")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/refract-ai"

command -v python3 >/dev/null 2>&1 || { echo "python3 required (to read the catalogs)." >&2; exit 1; }

# ---- argument parsing --------------------------------------------------------
DO_WRITE=1        # write config?
DO_ASK=""         # "" = auto (ask iff TTY); 1 = force ask; 0 = never ask
FORCE_TIER=""; FORCE_PROFILE=""; FORCE_IMAGE=""
while [ $# -gt 0 ]; do
    case "$1" in
        --print)   DO_WRITE=0; DO_ASK=0 ;;
        --yes|-y)  DO_ASK=0 ;;
        --tier)    FORCE_TIER="${2:-}"; shift ;;
        --profile) FORCE_PROFILE="${2:-}"; shift ;;
        --image)   FORCE_IMAGE="${2:-}"; shift ;;
        -h|--help)
            sed -n '2,45p' "$SELF" | sed 's/^# \{0,1\}//'; exit 0 ;;
        *) echo "Unknown arg: $1 (see --help)" >&2; exit 1 ;;
    esac
    shift
done
# Default: ask only when connected to a terminal.
[ -n "$DO_ASK" ] || { [ -t 0 ] && [ -t 1 ] && DO_ASK=1 || DO_ASK=0; }

valid_tier()    { case "$1" in cpu|entry|mid|high|max|ultra) return 0;; *) return 1;; esac; }
valid_profile() { case "$1" in efficiency|balance|power) return 0;; *) return 1;; esac; }

# ---- GPU enumeration (all inputs env-overridable) ----------------------------
# gather_gpus -> prints "<mib>\t<name>" per detected GPU (Nvidia then AMD).
gather_gpus() {
    if [ -n "${REFRACT_GPU_LIST:-}" ]; then
        # test/override form: "mib:name;mib:name". Split on ';' then first ':'.
        local IFS=';' pair
        for pair in $REFRACT_GPU_LIST; do
            [ -n "$pair" ] || continue
            printf '%s\t%s\n' "${pair%%:*}" "${pair#*:}"
        done
        return
    fi
    local smi="${NVIDIA_SMI:-nvidia-smi}" line mem name f bytes mib
    if command -v "$smi" >/dev/null 2>&1; then
        # "32607, NVIDIA GeForce RTX 5090"
        while IFS= read -r line; do
            [ -n "$line" ] || continue
            mem="${line%%,*}"; name="${line#*, }"
            mem="${mem// /}"
            [[ "$mem" =~ ^[0-9]+$ ]] || continue
            printf '%s\t%s\n' "$mem" "$name"
        done < <("$smi" --query-gpu=memory.total,name --format=csv,noheader,nounits 2>/dev/null || true)
    fi
    for f in "${SYS_DRM_ROOT:-/sys/class/drm}"/card*/device/mem_info_vram_total; do
        [ -r "$f" ] || continue
        bytes="$(cat "$f" 2>/dev/null || echo 0)"
        [[ "$bytes" =~ ^[0-9]+$ ]] || continue
        mib=$(( bytes / 1048576 ))
        # Tag each card by its PCI device id so compute_vram only pools
        # physically-identical cards. Without this, a discrete Radeon and a
        # Ryzen iGPU/APU carveout (or two different Radeons) would all be named
        # "AMD GPU", get summed into one group, and could cross a tier boundary.
        did="$(cat "$(dirname "$f")/device" 2>/dev/null || echo '?')"
        printf '%s\tAMD GPU %s\n' "$mib" "$did"
    done
}

# classify a GPU name: datacenter | nvl | consumer
# Datacenter substrings are matched FIRST; only H100/H200 NVL (the air-cooled
# single-card-in-a-workstation edge case) is downgraded to 'nvl' (allow-with-
# warning). Everything else datacenter -> 'datacenter' (hard Server-mode route).
# Order matters: a top-level *nvl* match would wrongly whitelist A100 NVL /
# "HGX B200 NVL72" and defeat the guard.
classify_gpu() {
    local n; n="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
    # AMD Instinct datacenter cards report ONLY their PCI device id via sysfs
    # (gather_gpus emits "AMD GPU 0xNNNN"), never a human name like "MI300X" — so
    # match the amdgpu device ids directly, or the guard would miss them:
    #   MI300 family 0x74a0/74a1/74a2/74a5/74a9 · MI200 0x7408/740c/740f · MI100 0x7388/738c/738e
    case "$n" in
        *0x74a0*|*0x74a1*|*0x74a2*|*0x74a5*|*0x74a9*|*0x7408*|*0x740c*|*0x740f*|*0x7388*|*0x738c*|*0x738e*)
            echo datacenter; return ;;
    esac
    # Note: *b100*/*b200* also match GB100/GB200 (Grace-Blackwell) by substring.
    case "$n" in
        *a100*|*a800*|*h100*|*h200*|*h800*|*b100*|*b200*|\
        *mi250*|*mi300*|*mi325*|*mi350*|*"data center gpu max"*|*gaudi*|*grace*)
            case "$n" in
                *h100*nvl*|*nvl*h100*|*h200*nvl*|*nvl*h200*) echo nvl; return ;;
            esac
            echo datacenter; return ;;
    esac
    echo consumer
}

# compute_vram: reads "<mib>\t<name>" lines on stdin, prints
# "<pooled>\t<single>\t<count>\t<name>".
# pooled = largest sum over a HOMOGENEOUS same-name group (Ollama pools those);
# single = largest single card; count = number of GPUs in the winning group;
# name = that winning group's name — the caller reports the GPU the tier actually
# came from, which on an APU + dGPU box is NOT the first-probed card.
# NOTE: uses `python3 -c` (not a heredoc) so the piped GPU list stays on stdin —
# a `python3 - <<HEREDOC` would make the heredoc itself python's stdin.
compute_vram() {
    python3 -c '
import sys
from collections import defaultdict
groups = defaultdict(lambda: [0, 0])  # name -> [sum_mib, count]
single = 0
for line in sys.stdin:
    line = line.rstrip("\n")
    if not line.strip():
        continue
    parts = line.split("\t")
    try:
        mib = int(parts[0])
    except (ValueError, IndexError):
        continue
    name = parts[1] if len(parts) > 1 and parts[1] else "GPU"
    groups[name][0] += mib
    groups[name][1] += 1
    single = max(single, mib)
if groups:
    # max() keeps the first group on a tie, i.e. probe order (nvidia before amd).
    name, win = max(groups.items(), key=lambda kv: kv[1][0])
    pooled, count = win
else:
    name, pooled, count = "", 0, 0
print("%d\t%d\t%d\t%s" % (pooled, single, count, name))
'
}

detect_is_laptop() {
    if [ -n "${REFRACT_IS_LAPTOP:-}" ]; then echo "$REFRACT_IS_LAPTOP"; return; fi
    local chassis b
    chassis="$(cat "${SYS_DMI_CHASSIS:-/sys/class/dmi/id/chassis_type}" 2>/dev/null || echo 0)"
    case "$chassis" in
        8|9|10|11|14|30|31|32) echo 1; return ;;   # portable/laptop/notebook/handheld/tablet/convertible/detachable
    esac
    for b in "${SYS_POWER_ROOT:-/sys/class/power_supply}"/BAT*; do
        [ -e "$b" ] && { echo 1; return; }
    done
    echo 0
}

detect_ram_mb() {
    if [ -n "${REFRACT_RAM_MB:-}" ]; then echo "$REFRACT_RAM_MB"; return; fi
    local kb
    kb="$(awk '/^MemTotal:/{print $2}' "${PROC_MEMINFO:-/proc/meminfo}" 2>/dev/null || echo 0)"
    [[ "$kb" =~ ^[0-9]+$ ]] || kb=0
    echo $(( kb / 1024 ))
}

# ---- Intel Arc detection — env-overridable, no root needed -------------------
# Neither Intel Arc flavour is visible to the probes above: an INTEGRATED Arc has
# no dedicated VRAM at all, and a DISCRETE one has VRAM that nothing exports
# (mem_info_vram_total is amdgpu-only). Both would drop us to the cpu tier, yet
# Ollama can drive either via its opt-in Vulkan backend — so detect them here with
# injectable probes, and tell the two apart (they differ in how they are tiered).

# intel_vga_lines: the Intel VGA/Display/3D controller lines of `lspci -nn`
# (empty when there are none, or when lspci is not installed).
# (REFRACT_LSPCI injects the lspci output for hermetic tests.)
intel_vga_lines() {
    local out
    if [ -n "${REFRACT_LSPCI:-}" ]; then
        out="$REFRACT_LSPCI"
    else
        command -v lspci >/dev/null 2>&1 || return 0
        out="$(lspci -nn 2>/dev/null || true)"
    fi
    printf '%s\n' "$out" \
        | grep -iE 'VGA compatible controller|Display controller|3D controller' \
        | grep -i 'intel' || true
}

# intel_vga_present: does lspci list ANY Intel VGA/Display/3D controller?
intel_vga_present() { [ -n "$(intel_vga_lines)" ]; }

# intel_discrete_lines: those of the Intel controllers that are DISCRETE cards
# rather than the on-package iGPU (empty if none). The PCI address is the
# discriminator: Intel integrated graphics always sit at 00:02.x on the root
# complex, while a discrete Arc sits behind a PCIe port on another bus. The
# marketing name cannot decide this ("Arc" is equally the brand of the
# Meteor/Lunar Lake iGPUs), and there is no size probe to fall back on —
# mem_info_vram_total is amdgpu-only and neither i915 nor xe exports an
# equivalent — so this reports PRESENCE only and the caller floors the tier
# rather than inventing a VRAM figure.
# (A GPU passed through to a VM can land at another address; --tier overrides it.)
intel_discrete_lines() {
    intel_vga_lines | grep -vE '^([0-9a-fA-F]{4}:)?00:02\.' || true
}

intel_discrete_present() { [ -n "$(intel_discrete_lines)" ]; }

# intel_discrete_desc: name the discrete card from the lspci line that proved it
# discrete, NOT from intel_vulkan_device: on an iGPU + discrete-Arc box vulkaninfo
# lists both and the first Intel match is usually the iGPU, so the Vulkan name can
# belong to the wrong device. Turns
#   "03:00.0 VGA compatible controller [0300]: Intel Corporation DG2 [Arc A770] [8086:56a0] (rev 08)"
# into "Intel Corporation DG2 [Arc A770]". Empty if there is no discrete line.
intel_discrete_desc() {
    local first d
    first="$(intel_discrete_lines)"
    first="${first%%$'\n'*}"     # first line, via expansion (a |head can SIGPIPE)
    [ -n "$first" ] || return 0
    d="${first#*: }"             # drop the "<bdf> <class> [class-id]: " prefix
    printf '%s' "${d%% \[8086:*}"  # drop the trailing "[8086:dddd] (rev NN)"
}

# intel_vulkan_device: echoes the Vulkan deviceName and returns 0 iff
# `vulkaninfo --summary` exposes a REAL Arc/Intel device — NOT Mesa's llvmpipe
# software rasterizer (which is what shows up when the Vulkan userspace is too old
# or absent). Returns 1 and echoes nothing otherwise. Never uses grep -q on a pipe
# (SIGPIPE + pipefail can misreport a match). (REFRACT_VULKAN_SUMMARY injects text.)
intel_vulkan_device() {
    local out line name low
    if [ -n "${REFRACT_VULKAN_SUMMARY:-}" ]; then
        out="$REFRACT_VULKAN_SUMMARY"
    else
        command -v vulkaninfo >/dev/null 2>&1 || return 1
        out="$(vulkaninfo --summary 2>/dev/null || true)"
    fi
    while IFS= read -r line; do
        case "$line" in *deviceName*) ;; *) continue ;; esac
        read -r name <<< "${line#*=}"          # value after '=', whitespace-trimmed
        low="$(printf '%s' "$name" | tr '[:upper:]' '[:lower:]')"
        case "$low" in
            *llvmpipe*)     continue ;;         # software rasterizer — not a usable GPU
            *arc*|*intel*)  printf '%s' "$name"; return 0 ;;
        esac
    done <<< "$out"
    return 1
}

# enable_ollama_vulkan: Ollama's Vulkan backend is opt-in (OLLAMA_VULKAN=1). Drop a
# systemd override into the system 'ollama' service so an Arc iGPU actually gets
# used. No-ops (prints a hint instead) unless we're root with a live systemd — so
# it's harmless run unprivileged or inside a build chroot.
enable_ollama_vulkan() {
    if [ "$(id -u)" != 0 ] || [ ! -d /run/systemd/system ] || ! command -v systemctl >/dev/null 2>&1; then
        echo "  (To use the Arc iGPU, enable Ollama's Vulkan backend as root:"
        echo "     sudo systemctl edit ollama   # add:  Environment=\"OLLAMA_VULKAN=1\")"
        return 0
    fi
    local dir="/etc/systemd/system/ollama.service.d"
    mkdir -p "$dir"
    printf '[Service]\nEnvironment="OLLAMA_VULKAN=1"\n' > "$dir/10-refract-vulkan.conf"
    systemctl daemon-reload || true
    systemctl restart ollama 2>/dev/null || true
    cl 32 "  Enabled Ollama Vulkan backend (OLLAMA_VULKAN=1) + restarted ollama."
}

tier_for_vram() {  # <vram_mib> -> tier
    local v="$1"
    if   [ "$v" -lt 5120 ];  then echo cpu
    elif [ "$v" -lt 11264 ]; then echo entry
    elif [ "$v" -lt 20480 ]; then echo mid
    elif [ "$v" -lt 30720 ]; then echo high
    elif [ "$v" -lt 46080 ]; then echo max     # 30-45GB: RTX 5090 32GB class
    else echo ultra; fi                          # >=45GB: 48-96GB workstation (or 2x pooled)
}

# tier_for_igpu_ram: an Intel iGPU has no VRAM — tier by how much system RAM is
# usable for models after leaving ~6 GiB headroom for the OS/desktop.
#   <4 GiB usable -> cpu | 4-12 -> entry | >=12 -> mid.
# The cpu floor is not cosmetic: a 4-8GB Intel laptop has <=2 GiB usable, which
# cannot hold an entry-tier 7-8B model. Without the floor, having an iGPU tiered
# such a box HIGHER ('entry') than the very same box without one (correctly
# 'cpu' — the iGPU adds no memory, it shares the RAM we just measured).
# A 16GB Arc laptop (~10 GiB usable) lands 'entry'; a 32GB one (~26 GiB) 'mid'.
# An iGPU never reaches high/max/ultra — it's shared, bandwidth-limited memory.
tier_for_igpu_ram() {  # <usable_mib> -> cpu|entry|mid
    local u="$1"
    if   [ "$u" -lt 4096 ];  then echo cpu
    elif [ "$u" -lt 12288 ]; then echo entry
    else echo mid; fi
}

# ---- catalog helpers ---------------------------------------------------------
catalog_for() { echo "$SCRIPT_DIR/../config/models.catalog.$1.json"; }

image_tokens() {
    CATALOG="$(catalog_for "$1")" python3 - <<'PY'
import json, os
tokmap = {"sdxl": ("sdxl", "SDXL base (fast, ~7GB, any dGPU)"),
          "flux1-schnell": ("flux-schnell", "FLUX.1-schnell (Apache-2.0, no token, ~12GB VRAM)"),
          "flux1-dev": ("flux-dev", "FLUX.1-dev (best quality, GATED: needs HF token)")}
try:
    cat = json.load(open(os.environ["CATALOG"]))
except Exception:
    cat = {"use_cases": {}}
uc = cat.get("use_cases", {}).get("image")
seen = []
if uc:
    for k, v in uc.items():
        if k in ("label", "runtime"): continue
        if v in tokmap and tokmap[v][0] not in [s[0] for s in seen]:
            seen.append(tokmap[v])
for tok, lbl in seen:
    print(f"{tok}\t{lbl}")
print("none\tNo image generation")
PY
}

default_image_token() {
    CATALOG="$(catalog_for "$1")" python3 - <<'PY'
import json, os
tokmap = {"sdxl": "sdxl", "flux1-schnell": "flux-schnell", "flux1-dev": "flux-dev"}
try:
    cat = json.load(open(os.environ["CATALOG"]))
except Exception:
    cat = {}
uc = (cat.get("use_cases") or {}).get("image") or {}
best = uc.get("best") or uc.get("alt") or uc.get("fast")
print(tokmap.get(best, "none"))
PY
}

c()  { printf '\033[%sm%s\033[0m' "$1" "$2"; }      # inline (no newline)
cl() { printf '\033[%sm%s\033[0m\n' "$1" "$2"; }    # whole colored line

# ---- enumerate GPUs + datacenter guard ---------------------------------------
GPU_LINES="$(gather_gpus)"

# Datacenter/headless silicon is Server-mode territory, not a desktop AI tier.
# Skip the guard if the user forced a tier or explicitly allowed datacenter.
if [ -z "${REFRACT_ALLOW_DATACENTER:-}" ] && [ -z "$FORCE_TIER" ] && [ -n "$GPU_LINES" ]; then
    dc_hit=""; nvl_warn=""
    while IFS=$'\t' read -r _mib _name; do
        [ -n "${_name:-}" ] || continue
        case "$(classify_gpu "$_name")" in
            datacenter) dc_hit="$_name" ;;
            nvl)        nvl_warn="$_name" ;;
        esac
    done <<< "$GPU_LINES"
    if [ -n "$dc_hit" ]; then
        cl 33 "Detected server-class hardware: $dc_hit"
        echo "Refract OS AI mode is a local-first DESKTOP experience (Ollama + ComfyUI)."
        echo "Datacenter GPUs belong in Server mode's headless serving path (Ollama / vLLM),"
        echo "not a desktop AI tier — a desktop chat GUI is the wrong shape for this hardware."
        echo ""
        echo "  -> Use Server mode:   distro-modectl switch server"
        echo "  -> Force a desktop tier anyway:  distro-ai-detect-tier --tier ultra"
        echo "     (or export REFRACT_ALLOW_DATACENTER=1)"
        exit 3
    fi
    if [ -n "$nvl_warn" ]; then
        cl 33 "Note: $nvl_warn is an NVL datacenter card in a workstation — allowed as a desktop 'ultra' tier,"
        echo "but it still needs the datacenter driver branch. Consider Server mode for headless serving."
    fi
fi

# ---- effective VRAM (multi-GPU homogeneous pool) -----------------------------
POOLED=0; SINGLE=0; GPU_COUNT=0; GPU_NAME=""
if [ -n "$GPU_LINES" ]; then
    IFS=$'\t' read -r POOLED SINGLE GPU_COUNT GPU_NAME <<< "$(printf '%s\n' "$GPU_LINES" | compute_vram)"
fi
# Explicit override forces the VRAM figure used for tiering.
if [ -n "${REFRACT_VRAM_MIB:-}" ]; then
    [[ "$REFRACT_VRAM_MIB" =~ ^[0-9]+$ ]] || { echo "REFRACT_VRAM_MIB must be an integer (MiB), got '$REFRACT_VRAM_MIB'." >&2; exit 1; }
    POOLED="$REFRACT_VRAM_MIB"; SINGLE="$REFRACT_VRAM_MIB"; GPU_COUNT=1
fi
VRAM_MIB="$POOLED"
# Name the GPU after the group compute_vram actually POOLED, not the first card
# probed: on an APU + dGPU box the first line is the iGPU carveout while the tier
# comes from the dGPU's group, so a positional name printed the iGPU's name next
# to the dGPU's VRAM.
GPU_DESC="$GPU_NAME"
[ -n "$GPU_DESC" ] || GPU_DESC="no dedicated GPU (integrated / CPU)"
IS_LAPTOP="$(detect_is_laptop)"
RAM_MB="$(detect_ram_mb)"
VRAM_GIB="$(python3 -c "print(round($VRAM_MIB/1024, 1))")"
RAM_GIB="$(python3 -c "print(round($RAM_MB/1024, 1))")"

# ---- Intel Arc fallback (after nvidia/amd, before the cpu fallback) -----------
# The Nvidia/AMD probes found no usable VRAM (VRAM_MIB below the cpu cutoff).
# Before settling for the cpu tier, look for an Intel Arc — integrated OR discrete
# (neither is visible to those probes) — that Ollama could drive over Vulkan.
# Skipped when a tier is forced or a real Nvidia/AMD dGPU was found.
INTEL_ARC=""            # Vulkan device name once a real Arc is confirmed
INTEL_TIER=""           # tier chosen for that Arc
INTEL_DISCRETE=""       # 1 when that Arc is a discrete card, not the iGPU
usable_mib=0
if [ -z "$FORCE_TIER" ] && [ "$VRAM_MIB" -lt 5120 ] && intel_vga_present; then
    if INTEL_ARC="$(intel_vulkan_device)"; then
        if intel_discrete_present; then
            # A discrete Arc has its OWN VRAM, so tiering it by system RAM the way
            # an iGPU is tiered would read a number that has nothing to do with the
            # card (a 64GB box with a 6GB A380 would land 'mid'). Nothing exports
            # its size (see intel_discrete_present), so do not invent one: floor the
            # tier at 'entry' — every discrete Arc ships >=6GB, which IS the entry
            # band — and point at --tier for the bigger cards. Under-promises rather
            # than guessing a VRAM figure we cannot measure.
            INTEL_DISCRETE=1
            INTEL_TIER="entry"
            GPU_DESC="$(intel_discrete_desc)"
            GPU_DESC="${GPU_DESC:-$INTEL_ARC} (discrete Intel GPU)"
        else
            usable_mib=$(( RAM_MB - 6144 ))      # leave ~6 GiB for the OS/desktop
            [ "$usable_mib" -lt 0 ] && usable_mib=0
            INTEL_TIER="$(tier_for_igpu_ram "$usable_mib")"
            GPU_DESC="$INTEL_ARC (Intel Arc iGPU — shares system RAM)"
        fi
    else
        INTEL_ARC=""
        cl 33 "WARNING: Intel graphics present, but Vulkan exposes no usable Arc device (only llvmpipe / software)."
        echo "  Ollama can't use the iGPU without the Vulkan userspace (recent Mesa + vulkan-loader + intel driver)."
        echo "  Falling back to the cpu tier. Install the Vulkan stack, then rerun: distro-ai-detect-tier"
    fi
fi

if [ -n "$FORCE_TIER" ]; then
    TIER="$FORCE_TIER"
elif [ -n "$INTEL_ARC" ]; then
    TIER="$INTEL_TIER"        # iGPU: tiered by shared RAM; discrete Arc: entry floor
else
    TIER="$(tier_for_vram "$VRAM_MIB")"
fi
valid_tier "$TIER" || { echo "Invalid --tier '$TIER' (cpu entry mid high max ultra)." >&2; exit 1; }

if [ -n "$FORCE_PROFILE" ]; then
    PROFILE="$FORCE_PROFILE"
elif [ "$IS_LAPTOP" = "1" ]; then
    PROFILE="balance"
else
    PROFILE="power"   # desktop always runs the best models the tier allows
fi
valid_profile "$PROFILE" || { echo "Invalid --profile '$PROFILE' (efficiency balance power)." >&2; exit 1; }

IMAGE="${FORCE_IMAGE:-$(default_image_token "$TIER")}"

# ---- report ------------------------------------------------------------------
cl 36 '== Refract AI hardware detection =='
printf '  %-14s %s\n' "GPU:"    "$GPU_DESC"
if [ -n "$INTEL_DISCRETE" ]; then
    printf '  %-14s %s\n' "VRAM:" "not probeable on Intel dGPUs — tier floored at 'entry' (override: --tier)"
elif [ -n "$INTEL_ARC" ]; then
    printf '  %-14s %s\n' "VRAM:" "n/a — integrated GPU shares system RAM"
    printf '  %-14s %s GiB usable for models (RAM - 6 GiB headroom)\n' \
        "Shared mem:" "$(python3 -c "print(round($usable_mib/1024, 1))")"
elif [ "${GPU_COUNT:-0}" -gt 1 ]; then
    printf '  %-14s %s GiB pooled across %s x %s (%s MiB); largest single %s MiB\n' \
        "VRAM:" "$VRAM_GIB" "$GPU_COUNT" "$GPU_DESC" "$VRAM_MIB" "$SINGLE"
else
    printf '  %-14s %s GiB (%s MiB)\n' "VRAM:" "$VRAM_GIB" "$VRAM_MIB"
fi
printf '  %-14s %s GiB\n' "RAM:"  "$RAM_GIB"
printf '  %-14s %s\n' "Form factor:" "$([ "$IS_LAPTOP" = 1 ] && echo laptop || echo desktop)"
printf '  %-14s %s\n' "-> Tier:"  "$(c 32 "$TIER")"
echo ""

if [ "$RAM_MB" -gt 0 ] && [ "$RAM_MB" -lt 4096 ]; then
    cl 33 "WARNING: only ${RAM_GIB} GiB RAM — even cpu-tier 3B models want ~4GB+ free. Expect swapping."
fi
if [ -n "$INTEL_DISCRETE" ]; then
    cl 33 "Discrete Intel GPU: usable via Ollama's Vulkan backend (OLLAMA_VULKAN=1), but its VRAM size cannot be"
    echo "  probed (the sysfs VRAM node is amdgpu-only), so this tier is a conservative FLOOR, not a measurement."
    echo "  Set it from the card's spec, e.g.:  distro-ai-detect-tier --tier mid   # A770 16GB / B580 12GB"
elif [ -n "$INTEL_ARC" ]; then
    cl 32 "Intel Arc iGPU usable via Ollama's Vulkan backend (OLLAMA_VULKAN=1); tiered by shared RAM, not VRAM."
fi
if [ "$TIER" = "cpu" ]; then
    if [ -n "$INTEL_ARC" ]; then
        # Reachable since tier_for_igpu_ram grew its cpu floor: the iGPU is real and
        # still runs the model over Vulkan, there is just too little shared RAM to
        # justify a bigger tier. Saying "no VRAM detected" here would be a lie.
        cl 33 "Only $(python3 -c "print(round($usable_mib/1024, 1))") GiB of shared RAM is usable for models -> cpu tier (<=3B models)."
        echo "The Arc iGPU is still used for them; more RAM raises this (or force it: distro-ai-detect-tier --tier entry)."
    else
        cl 33 'No usable dedicated VRAM detected -> cpu tier (CPU inference, no image generation).'
        echo "If you have a discrete GPU we missed, rerun with an explicit tier: distro-ai-detect-tier --tier entry|mid|high|max"
    fi
fi
if [ "$TIER" = "ultra" ]; then
    cl 32 "Ultra tier: 70B runs FULLY in VRAM (no CPU offload). 96GB+ also unlocks 104B/123B and gpt-oss-120B."
fi

# ---- interactive choices -----------------------------------------------------
ask_profile() {
    [ "$IS_LAPTOP" = "1" ] || return 0          # desktops don't choose
    [ -n "$FORCE_PROFILE" ] && return 0
    cl 36 'Laptop power profile:'
    echo "  1) efficiency  - the lightest model each use-case offers: fastest, least battery drain"
    echo "  2) balance     - the best models this tier fits (default)"
    echo "  3) power       - the best models this tier fits, same as a desktop"
    echo "                   (2 and 3 pick the same model: the tier already caps model size)"
    local ans
    read -r -p "Choose 1/2/3 [2]: " ans || ans=""
    case "$ans" in
        1) PROFILE="efficiency" ;;
        3) PROFILE="power" ;;
        *) PROFILE="balance" ;;
    esac
}

ask_image() {
    [ -n "$FORCE_IMAGE" ] && return 0
    local rows=(); mapfile -t rows < <(image_tokens "$TIER")
    if [ "${#rows[@]}" -le 1 ]; then IMAGE="none"; return 0; fi
    cl 36 'Image generation (pick one to preload, runs in ComfyUI):'
    local i=1 tok lbl
    for row in "${rows[@]}"; do
        IFS=$'\t' read -r tok lbl <<< "$row"
        printf '  %d) %-12s %s\n' "$i" "$tok" "$lbl"
        i=$((i+1))
    done
    local ans; read -r -p "Choose 1-${#rows[@]} [1]: " ans || ans=""
    [[ "$ans" =~ ^[0-9]+$ ]] && [ "$ans" -ge 1 ] && [ "$ans" -le "${#rows[@]}" ] || ans=1
    IFS=$'\t' read -r IMAGE _ <<< "${rows[$((ans-1))]}"
}

if [ "$DO_ASK" = "1" ]; then
    ask_profile
    ask_image
fi

echo ""
printf '  %-14s %s\n' "Profile:" "$(c 32 "$PROFILE")"
printf '  %-14s %s\n' "Image gen:" "$(c 32 "$IMAGE")"

# ---- persist -----------------------------------------------------------------
if [ "$DO_WRITE" = "1" ]; then
    mkdir -p "$CONFIG_HOME"
    printf '%s\n' "$TIER"     > "$CONFIG_HOME/tier"
    printf '%s\n' "$PROFILE"  > "$CONFIG_HOME/profile"
    printf '%s\n' "$IMAGE"    > "$CONFIG_HOME/image"
    printf '%s\n' "$VRAM_MIB" > "$CONFIG_HOME/vram_mib"
    {
        echo "# Written by distro-ai-detect-tier"
        echo "gpu=$GPU_DESC"
        echo "gpu_count=$GPU_COUNT"
        echo "vram_mib=$VRAM_MIB"
        echo "vram_single_mib=$SINGLE"
        echo "ram_mb=$RAM_MB"
        echo "is_laptop=$IS_LAPTOP"
        echo "tier=$TIER"
        echo "profile=$PROFILE"
        echo "image=$IMAGE"
        echo "intel_arc=$INTEL_ARC"
        echo "intel_discrete=$INTEL_DISCRETE"
    } > "$CONFIG_HOME/detected"
    echo ""
    cl 32 "Wrote $CONFIG_HOME/{tier,profile,image,vram_mib}."
    if [ -n "$INTEL_ARC" ]; then
        enable_ollama_vulkan
    fi
    echo "Next: preload the models for this tier ->"
    echo "  modes/ai/setup/02-preload-models.sh          # pulls the tier's coding model (one model)"
    if [ "$IMAGE" != "none" ]; then
        echo "  modes/ai/setup/04-download-image-models.sh --from-config   # $IMAGE image model"
    fi
    echo "Then load one:  distro-ai-model use coding"
else
    echo ""
    echo "(--print: nothing written. Re-run without --print to save, or pass --yes.)"
fi
