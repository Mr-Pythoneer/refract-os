#!/usr/bin/env bash
#
# Shared backend for the hotkey overlay and the Nautilus "ask AI about this
# file" action (modes/ai/integrations/nautilus-ask-ai). Both are thin clients
# on top of whatever model Ollama has loaded -- this just does an
# OpenAI-compatible HTTP call to Ollama's server, no new inference logic.
#
# Usage:
#   distro-ai-ask "<prompt text>"
#   echo "<prompt text>" | distro-ai-ask
#
# Reads the prompt from $1 if given, otherwise from stdin. Prints the model's
# reply to stdout. Exits non-zero (with a message on stderr) if Ollama isn't
# reachable -- callers (overlay/Nautilus script) are expected to surface that to
# the user rather than failing silently.
#
# REFRACT_AI_TIMEOUT (seconds, default 300) bounds the chat request; it has to
# cover a cold model load, not just generation.

set -euo pipefail

# Ollama's OpenAI-compatible endpoint. Port 11434 (was LM Studio's 8080).
# OLLAMA_HOST lets a remote/relocated daemon be targeted; default localhost.
BASE="${OLLAMA_HOST:-127.0.0.1:11434}"
case "$BASE" in http://*|https://*) ;; *) BASE="http://$BASE" ;; esac
ENDPOINT="$BASE/v1/chat/completions"

# Seconds allowed for the chat request. Must cover a cold model load plus
# generation (see the curl call below); override for slow disks / huge models.
TIMEOUT="${REFRACT_AI_TIMEOUT:-300}"
[[ "$TIMEOUT" =~ ^[0-9]+$ ]] || { echo "distro-ai-ask: REFRACT_AI_TIMEOUT must be an integer (seconds), got '$TIMEOUT'" >&2; exit 1; }

if [ -n "${1:-}" ]; then
    prompt="$1"
else
    prompt="$(cat)"
fi

if [ -z "$prompt" ]; then
    echo "distro-ai-ask: empty prompt" >&2
    exit 1
fi

if ! command -v curl >/dev/null 2>&1; then
    echo "distro-ai-ask: curl is required but not found" >&2
    exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
    echo "distro-ai-ask: python3 is required (used for JSON encode/decode) but not found" >&2
    exit 1
fi

# Ollama's OpenAI endpoint REQUIRES a model field (LM Studio inferred the loaded
# one). Preserve "ask whatever's loaded": take the first model Ollama reports as
# resident (/api/ps); fall back to the first installed model (/api/tags).
model="$(curl -sS --max-time 5 "$BASE/api/ps" 2>/dev/null | python3 -c '
import json,sys
try: print(json.load(sys.stdin).get("models",[{}])[0].get("name",""))
except Exception: print("")
' 2>/dev/null || true)"
if [ -z "$model" ]; then
    model="$(curl -sS --max-time 5 "$BASE/api/tags" 2>/dev/null | python3 -c '
import json,sys
try: print(json.load(sys.stdin).get("models",[{}])[0].get("name",""))
except Exception: print("")
' 2>/dev/null || true)"
fi
if [ -z "$model" ]; then
    echo "distro-ai-ask: no model is loaded or installed. Pull one first: distro-ai-model use coding" >&2
    exit 1
fi

payload="$(PROMPT="$prompt" MODEL="$model" python3 -c '
import json, os
print(json.dumps({
    "model": os.environ["MODEL"],
    "messages": [{"role": "user", "content": os.environ["PROMPT"]}],
    "stream": False,
}))
')"

# This request can trigger a COLD model load: Ollama evicts a model after its
# keep_alive (~5 min idle) expires, and after a reboot nothing is resident at all
# -- the load then happens INSIDE this call, so the budget must cover load +
# generation, not just generation. distro-ai-model gives the same load 300s; a
# 60s budget here made a healthy box report "is Ollama running?". Connecting is
# separate and fast, so a refused/dead daemon still fails in ~5s rather than
# after the full budget.
rc=0
response="$(curl -sS --connect-timeout 5 --max-time "$TIMEOUT" -X POST "$ENDPOINT" \
    -H "Content-Type: application/json" \
    -d "$payload" 2>&1)" || rc=$?
if [ "$rc" -ne 0 ]; then
    # curl exit 7 = connection refused (nothing listening); 28 = timed out (either
    # --connect-timeout or --max-time). They mean opposite things to the user, so
    # do not report both as "is Ollama running?".
    case "$rc" in
        7)  echo "distro-ai-ask: nothing is listening on $ENDPOINT -- is Ollama running? Try: systemctl status ollama  (and: distro-ai-model status)" >&2 ;;
        28) echo "distro-ai-ask: Ollama did not answer within ${TIMEOUT}s. A first/cold load of '$model' can take minutes; raise it with REFRACT_AI_TIMEOUT=600, or preload it: distro-ai-model load $model" >&2 ;;
        *)  echo "distro-ai-ask: request to $ENDPOINT failed (curl exit $rc)" >&2 ;;
    esac
    echo "$response" >&2
    exit 1
fi

reply="$(RESPONSE="$response" python3 -c '
import json, os, sys
try:
    data = json.loads(os.environ["RESPONSE"])
    print(data["choices"][0]["message"]["content"])
except (json.JSONDecodeError, KeyError, IndexError, TypeError) as e:
    print(f"distro-ai-ask: unexpected response shape ({e})", file=sys.stderr)
    print(os.environ["RESPONSE"], file=sys.stderr)
    sys.exit(1)
')" || exit 1

printf '%s\n' "$reply"
