#!/usr/bin/env bash
#
# AI-mode model control surface (Ollama). Replaces the legacy distro-ai-preset.
# Maps the use-case menu to concrete Ollama tags (the canonical model table
# below) and pulls/loads them via the Ollama daemon, which serves the
# OpenAI-compatible API on port 11434 (so the existing distro-ai-ask / overlay /
# nautilus clients work unchanged).
#
# Ollama's server is a SYSTEM service (the 'ollama' systemd unit running as the
# 'ollama' user), NOT per-user like LM Studio was. So the model CLI/API calls
# here work as any user against 127.0.0.1:11434, and the 'server' subcommands
# are thin wrappers over `systemctl {start,stop,status} ollama` (start/stop need
# sudo). The old per-tier models.catalog.*.json files were LM Studio catalogs
# (HuggingFace GGUF repos) and are superseded by the table below.
#
# Usage:
#   distro-ai-model list                       -- show use-cases + models
#   distro-ai-model use <use-case> [variant]   -- pull+load the best (or named) model for a use-case
#   distro-ai-model load <ollama-tag>          -- pull+load a specific Ollama tag
#   distro-ai-model server start|stop|status   -- control the ollama systemd service
#   distro-ai-model status                     -- what's loaded (ollama ps)
#   distro-ai-model unload                     -- unload all models
#
# e.g.  distro-ai-model use coding       (-> qwen2.5-coder:32b on a 5090, :7b on a laptop)
#       distro-ai-model use day-to-day alt   (-> gemma3:4b)

set -euo pipefail

# Resolve through the /usr/local/bin symlink (build.sh installs these as
# symlinks) so --help can print this header from the real script file.
SELF="${BASH_SOURCE[0]}"; [ -L "$SELF" ] && SELF="$(readlink "$SELF")"

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/refract-ai"
# Active AI-model tier (cpu/entry/mid/high/max/ultra) and laptop power profile
# (efficiency/balance/power). distro-ai-detect-tier writes these into
# $CONFIG_HOME; override via env. With NEITHER an env value nor a recorded tier
# we must NOT assume the 32GB 'max' build — defaulting to 'max' made a fresh box
# try to pull the ~20GB 32b model. Fall back to the conservative 'entry' tier and
# nudge the user to run distro-ai-detect-tier so the pick matches real hardware.
if [ -n "${REFRACT_AI_TIER:-}" ]; then
    TIER="$REFRACT_AI_TIER"
elif TIER="$(cat "$CONFIG_HOME/tier" 2>/dev/null)" && [ -n "$TIER" ]; then
    :   # used the recorded tier
else
    TIER="entry"
    echo "distro-ai-model: no tier recorded — assuming '$TIER'. Run 'distro-ai-detect-tier' to match your hardware." >&2
fi
PROFILE="${REFRACT_AI_PROFILE:-$(cat "$CONFIG_HOME/profile" 2>/dev/null || echo balance)}"
# Effective (pooled) VRAM in MiB, written by distro-ai-detect-tier. Used to warn
# when a tag wants more VRAM than this box has, and to skip a too-big default
# variant. 0/empty = unknown -> no gating (back-compat).
VRAM_MIB="${REFRACT_VRAM_MIB:-$(cat "$CONFIG_HOME/vram_mib" 2>/dev/null || echo 0)}"
[[ "$VRAM_MIB" =~ ^[0-9]+$ ]] || VRAM_MIB=0

# Ollama's server. Port 11434 (was LM Studio's 8080). OLLAMA_HOST lets a
# remote/relocated daemon be targeted; default localhost. /api/* is Ollama's
# native REST, /v1 is the OpenAI-compatible surface the thin clients use.
BASE="${OLLAMA_HOST:-127.0.0.1:11434}"
case "$BASE" in http://*|https://*) ;; *) BASE="http://$BASE" ;; esac

die() { echo "$1" >&2; exit 1; }
command -v python3 >/dev/null 2>&1 || die "python3 required to resolve the model table."
command -v curl    >/dev/null 2>&1 || die "curl required to talk to the Ollama API."

need_ollama() { command -v ollama >/dev/null 2>&1 || die "ollama CLI not found — run modes/ai/setup/01-install-ollama.sh first."; }

# Canonical model table (exact ollama.com tags). Low tier = X1-class
# shared-memory laptop (3-8B); high tier = RTX 5090 / 32GB-class dGPU. Each
# use-case carries a "high" and a "low" tag, plus optional lighter alternates
# ("cpu" = sub-4B for CPU/8GB boxes, "alt"/"light" = named extras). Pin exact
# tags, never ':latest', for reproducibility. Image gen stays in ComfyUI —
# Ollama has no diffusion backend on Linux.
read -r -d '' MODEL_TABLE <<'JSON' || true
{
  "use_cases": {
    "coding":      { "label": "Coding",            "high": "qwen2.5-coder:32b",      "low": "qwen2.5-coder:7b", "cpu": "qwen2.5-coder:3b" },
    "cad":         { "label": "CAD / Design",      "high": "qwen2.5-coder:32b",      "low": "qwen2.5-coder:7b", "cpu": "qwen2.5-coder:3b" },
    "day-to-day":  { "label": "Day-to-day",        "high": "qwen3:32b",              "low": "llama3.1:8b",      "alt": "gemma3:4b", "cpu": "gemma3:4b" },
    "know-it-all": { "label": "Know-it-all",       "high": "deepseek-r1:32b",        "low": "qwen3:8b",         "alt": "deepseek-r1:8b" },
    "uncensored":  { "label": "Uncensored",        "high": "dolphin-mixtral:8x7b",   "low": "dolphin3:8b" },
    "assistant":   { "label": "Desktop assistant", "high": "qwen3:30b-a3b-instruct", "low": "llama3.1:8b" },
    "vision":      { "label": "Image recognition", "high": "qwen2.5vl:32b",          "low": "qwen2.5vl:7b",     "light": "moondream:1.8b", "cpu": "moondream:1.8b" },
    "image":       { "label": "Image generation",  "runtime": "comfyui",             "best": "comfyui" }
  },
  "models": {
    "qwen2.5-coder:32b":      { "min_vram_gb": 20, "note": "Best coding/CAD; fits fully in 32GB VRAM." },
    "qwen2.5-coder:7b":       { "min_vram_gb": 6,  "note": "Fast coder for laptop-class GPUs." },
    "qwen2.5-coder:3b":       { "min_vram_gb": 3,  "note": "Tiny coder for ~8GB / CPU-only boxes." },
    "qwen3:32b":              { "min_vram_gb": 20 },
    "llama3.1:8b":            { "min_vram_gb": 6 },
    "gemma3:4b":              { "min_vram_gb": 4,  "note": "Lightweight day-to-day for small/CPU boxes." },
    "deepseek-r1:32b":        { "min_vram_gb": 20, "note": "Reasoning model." },
    "qwen3:8b":               { "min_vram_gb": 6 },
    "deepseek-r1:8b":         { "min_vram_gb": 6,  "note": "Reasoning (8B distill)." },
    "dolphin-mixtral:8x7b":   { "min_vram_gb": 28, "note": "Uncensored MoE; at the edge of 32GB VRAM." },
    "dolphin3:8b":            { "min_vram_gb": 6,  "note": "Uncensored." },
    "qwen3:30b-a3b-instruct": { "min_vram_gb": 20, "note": "MoE assistant (~3B active)." },
    "qwen2.5vl:32b":          { "min_vram_gb": 21, "vision": true },
    "qwen2.5vl:7b":           { "min_vram_gb": 7,  "vision": true },
    "moondream:1.8b":         { "min_vram_gb": 2,  "vision": true, "note": "Light vision fallback." },
    "comfyui":                { "runtime": "comfyui", "note": "Image generation runs in ComfyUI, not Ollama." }
  }
}
JSON

# table_py <python-expr-printing-output> — runs a python snippet with the model
# table available as os.environ["TABLE"] (JSON). Args after the snippet are
# sys.argv[1:]; TIER/VRAM_MIB/PROFILE are exported for selection.
table_py() { TABLE="$MODEL_TABLE" TIER="$TIER" VRAM_MIB="$VRAM_MIB" PROFILE="$PROFILE" python3 -c "$1" "${@:2}"; }

resolve_usecase_model() {  # <usecase> [variant] -> prints ollama tag
    table_py '
import json, os, sys
t = json.loads(os.environ["TABLE"])
ucs = t["use_cases"]; models = t["models"]
name = sys.argv[1]
variant = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] else None
uc = ucs.get(name)
if not uc:
    print("error: unknown use-case: {}".format(name), file=sys.stderr); sys.exit(2)
vram = int(os.environ.get("VRAM_MIB", "0") or 0)
skip = ("label", "runtime")
def fits(tag):
    mv = models.get(tag, {}).get("min_vram_gb")
    if not mv or vram <= 0: return True   # no requirement, or VRAM unknown -> allow
    return mv * 1024 <= vram
if variant:
    # Explicit variant: honor it exactly. Accept the legacy variant names the
    # old catalogs used (best/balanced/fast) as aliases so docs/tests still work.
    alias = {"best": "high", "balanced": "low", "fast": "cpu"}
    key = variant if variant in uc else alias.get(variant)
    tag = uc.get(key) if key else None
    if not tag:
        have = [k for k in uc if k not in skip]
        print("error: use-case {} has no variant {} (have: {})".format(name, variant, have), file=sys.stderr); sys.exit(2)
    print(tag); sys.exit(0)
# No explicit variant: pick low-vs-high by the detected tier. high/max/ultra ->
# the 32GB-class "high" tag; cpu -> the sub-4B "cpu" tag if present; everything
# else (entry/mid) -> the 7-8B "low" tag. Then skip any candidate that does not
# fit the detected VRAM (mainly a too-big "high" on a smaller box).
tier = os.environ.get("TIER", "max")
if tier in ("high", "max", "ultra"): base = ["high", "low", "cpu"]
elif tier == "cpu":                  base = ["cpu", "low", "high"]
else:                                base = ["low", "cpu", "high"]
# PROFILE then moves the pick WITHIN the tier, never above it: the tier is
# derived from MEASURED VRAM, so no tag heavier than the tier tag would fit
# anyway -- "power" (the best models the tier allows, i.e. same as a desktop)
# and the "balance" default therefore both land on the tier order above, and a
# 3-point profile cannot be 3-way distinct on the laptop tiers (entry/mid offer
# only two rungs: "low" and "cpu"). Only "efficiency" moves the pick: it trades
# quality for speed/battery by taking the LIGHTEST tag this use-case offers,
# ranked by the table min_vram_gb. A tag carrying no min_vram_gb (the ComfyUI
# pseudo-tag) ranks last so it is never mistaken for the lightest.
profile = os.environ.get("PROFILE", "balance")
if profile == "efficiency":
    order = sorted((k for k in uc if k not in skip),
                   key=lambda k: models.get(uc[k], {}).get("min_vram_gb") or 10 ** 6)
else:
    order = base + [k for k in uc if k not in skip and k not in base]
cands = [uc[k] for k in order if k in uc]
tag = next((c for c in cands if fits(c)), None)
if tag is None:   # nothing fits -> first candidate, load_model will warn
    tag = cands[0] if cands else None
print(tag if tag else "")   # empty (not "None") so the caller guard catches it
' "$@"
}

model_field() {  # <ollama-tag> <field> -> prints field (or empty)
    table_py '
import json, os, sys
t = json.loads(os.environ["TABLE"])
m = t["models"].get(sys.argv[1], {})
print(m.get(sys.argv[2], ""))
' "$@"
}

server_up()      { curl -sf --max-time 3 "$BASE/api/tags" >/dev/null 2>&1; }
model_present()  { ollama list 2>/dev/null | awk 'NR>1{print $1}' | grep -Fxq "$1"; }
loaded_models()  { ollama ps   2>/dev/null | awk 'NR>1{print $1}'; }

unload_all() {  # stop every resident model so only the next one occupies VRAM
    local m
    while IFS= read -r m; do
        [ -n "$m" ] || continue
        ollama stop "$m" >/dev/null 2>&1 || true
    done < <(loaded_models)
}

ensure_server() {
    need_ollama
    server_up && return 0
    # Ollama's API is served by the systemd 'ollama' service; (re)start it. This
    # needs root, so try sudo (fall back to a plain start in case we already are).
    sudo systemctl start ollama >/dev/null 2>&1 || systemctl start ollama >/dev/null 2>&1 || true
    local _
    for _ in 1 2 3 4 5; do server_up && return 0; sleep 1; done
    die "Ollama API not reachable on $BASE — start it: sudo systemctl start ollama  (status: systemctl status ollama)"
}

load_model() {  # <ollama-tag>
    local id="$1"
    local runtime note minv resp
    runtime="$(model_field "$id" runtime)"
    if [ "$runtime" = "comfyui" ]; then
        die "'$id' is an image-generation model (ComfyUI), not an Ollama model. Use: distro-ai-image"
    fi

    # Fit check: warn (don't block) if this tag wants more VRAM than detected.
    # Tolerate a float min_vram_gb (bash arithmetic is integer-only) by dropping
    # any fractional part before comparing.
    minv="$(model_field "$id" min_vram_gb)"; minv="${minv%%.*}"
    if [[ "$minv" =~ ^[0-9]+$ ]] && [ "$VRAM_MIB" -gt 0 ] && [ "$(( minv * 1024 ))" -gt "$VRAM_MIB" ]; then
        echo "WARNING: $id wants ~${minv}GB VRAM but only ~$(( VRAM_MIB / 1024 ))GB detected — Ollama will spill to system RAM (slow). A lighter variant may fit better." >&2
    fi

    ensure_server
    # Ensure the model is present. Pull only when missing so offline mode still
    # works for already-downloaded tags.
    if ! model_present "$id"; then
        echo "Pulling $id (first use) ..."
        ollama pull "$id" || die "Failed to pull $id. Check the tag/network (or preload: modes/ai/setup/02-preload-models.sh $id). Installed: ollama list"
    fi

    echo "Loading $id ..."
    unload_all   # one model at a time (VRAM)
    # Load into memory without a prompt and pin it resident (keep_alive:-1), the
    # Ollama equivalent of LM Studio's persistent `lms load`.
    resp="$(curl -sS --max-time 300 -X POST "$BASE/api/generate" \
        -H 'Content-Type: application/json' \
        -d "{\"model\":\"$id\",\"keep_alive\":-1}" 2>&1)" \
        || die "Failed to load $id — is Ollama running? (systemctl status ollama). Check: ollama ps"
    case "$resp" in *'"error"'*) die "Ollama could not load $id: $resp" ;; esac

    note="$(model_field "$id" note)"
    [ -n "$note" ] && echo "Note: $note"
    echo "Loaded. API: $BASE/v1 (model: $id)"
}

case "${1:-}" in
    list)
        echo "Active tier: $TIER   profile: $PROFILE$([ "$VRAM_MIB" -gt 0 ] && echo "   VRAM: ~$(( VRAM_MIB / 1024 ))GB")"
        echo "Tiers: cpu entry mid high max ultra  ·  set via distro-ai-detect-tier or \$REFRACT_AI_TIER"
        echo ""
        table_py '
import json, os
t = json.loads(os.environ["TABLE"])
print("Use-cases (high = 32GB+ dGPU, low = laptop/shared VRAM; picked by tier —")
print("or the lightest tag that fits when profile=efficiency):")
for name, uc in t["use_cases"].items():
    variants = ", ".join("{}={}".format(k, v) for k, v in uc.items() if k not in ("label", "runtime"))
    rt = " [ComfyUI]" if uc.get("runtime") == "comfyui" else ""
    print("  {:12s} {}{}: {}".format(name, uc.get("label", ""), rt, variants))
print("")
print("Models (Ollama tags):")
for mid, m in t["models"].items():
    tag = " (vision)" if m.get("vision") else (" (image/ComfyUI)" if m.get("runtime") == "comfyui" else "")
    mv = m.get("min_vram_gb")
    sz = " ~{}GB".format(mv) if mv else ""
    print("  {:26s}{}{}".format(mid, sz, tag))
'
        ;;
    use)
        [ $# -ge 2 ] || die "Usage: $(basename "$0") use <use-case> [variant]"
        # resolve_usecase_model prints its own error to stderr and exits 2.
        mid="$(resolve_usecase_model "$2" "${3:-}")" || exit 2
        [ -n "$mid" ] || die "No model mapped for use-case '$2'."
        # Image use-case routes to ComfyUI.
        if [ "$(model_field "$mid" runtime)" = "comfyui" ]; then
            echo "Use-case '$2' is image generation ($mid) — that runs in ComfyUI, not Ollama."
            echo "Start it with: distro-ai-image"
            exit 0
        fi
        load_model "$mid"
        ;;
    load)
        [ $# -ge 2 ] || die "Usage: $(basename "$0") load <ollama-tag>"
        load_model "$2"
        ;;
    server)
        need_ollama
        case "${2:-status}" in
            start)  sudo systemctl start ollama || die "Failed to start ollama (need sudo?). Try: sudo systemctl start ollama"; systemctl is-active ollama ;;
            stop)   sudo systemctl stop  ollama || die "Failed to stop ollama (need sudo?). Try: sudo systemctl stop ollama" ;;
            status) systemctl status ollama --no-pager 2>/dev/null || systemctl is-active ollama || true ;;
            *) die "Usage: $(basename "$0") server start|stop|status" ;;
        esac
        ;;
    status)
        need_ollama
        echo "Active tier: $TIER   profile: $PROFILE$([ "$VRAM_MIB" -gt 0 ] && echo "   VRAM: ~$(( VRAM_MIB / 1024 ))GB")"
        command -v systemctl >/dev/null 2>&1 && echo "Server (systemd ollama): $(systemctl is-active ollama 2>/dev/null || echo unknown)"
        if server_up; then echo "API: $BASE/v1 (reachable)"; else echo "API: $BASE/v1 (NOT reachable)"; fi
        echo "--- loaded models ---"
        ollama ps 2>/dev/null || echo "(none / ollama not running)"
        ;;
    unload)
        need_ollama
        unload_all && echo "Unloaded all models."
        ;;
    *)
        echo "Usage: $(basename "$0") list | use <use-case> [variant] | load <ollama-tag> | server start|stop|status | status | unload" >&2
        exit 1
        ;;
esac
